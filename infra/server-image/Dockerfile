# =====================================================================
# "Server" image — a stand-in for an EC2 instance.
# It's an Ubuntu box that runs an SSH server (so Ansible can log in)
# and a full Docker engine inside it (Docker-in-Docker), so the app
# stack runs ON this "server" exactly like it would on a real VM.
# =====================================================================
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Base tools: SSH server, sudo, python (required by Ansible), and the
# dependencies the Docker install script needs.
RUN apt-get update && apt-get install -y --no-install-recommends \
        openssh-server \
        sudo \
        python3 \
        curl \
        ca-certificates \
        iptables \
    && rm -rf /var/lib/apt/lists/*

# Install Docker engine (so dockerd can run inside this container).
RUN curl -fsSL https://get.docker.com | sh

# Create the 'deploy' user Ansible connects as (passwordless sudo).
RUN useradd -m -s /bin/bash deploy \
    && usermod -aG sudo,docker deploy \
    && echo 'deploy ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/deploy

# Install the SSH public key generated by Terraform (see main.tf).
RUN mkdir -p /home/deploy/.ssh /var/run/sshd
COPY authorized_keys /home/deploy/.ssh/authorized_keys
RUN chown -R deploy:deploy /home/deploy/.ssh \
    && chmod 700 /home/deploy/.ssh \
    && chmod 600 /home/deploy/.ssh/authorized_keys

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# 22 = SSH (for Ansible), 80 = the app's Nginx (for the load balancer)
EXPOSE 22 80

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
